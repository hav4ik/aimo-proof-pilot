Bootstrap: docker
From: pytorch/pytorch:2.11.0-cuda13.0-cudnn9-devel

%files
    ./src/* /app/

%environment
    export OPEN_INSTRUCT_DIR=/opt/open-instruct
    export OLMO_CORE_DIR=/opt/OLMo-core
    export PYTHONPATH=/app:/opt/open-instruct:/opt/OLMo-core/src:/opt/Megatron-LM
    export HF_HOME=/tmp/olmo_train_runtime_cache/hf
    export HUGGINGFACE_HUB_CACHE=/tmp/olmo_train_runtime_cache/hf
    export TRANSFORMERS_CACHE=/tmp/olmo_train_runtime_cache/hf
    export TORCH_HOME=/tmp/olmo_train_runtime_cache/torch
    export TORCHINDUCTOR_CACHE_DIR=/tmp/olmo_train_runtime_cache/torchinductor
    export TRITON_CACHE_DIR=/tmp/olmo_train_runtime_cache/triton
    export XDG_CACHE_HOME=/tmp/olmo_train_runtime_cache/xdg
    export FLASHINFER_CACHE_DIR=/tmp/olmo_train_runtime_cache/flashinfer
    export VLLM_CACHE_ROOT=/tmp/olmo_train_runtime_cache/vllm
    export WANDB_DIR=/tmp/olmo_train_runtime_cache/wandb
    export WANDB_CACHE_DIR=/tmp/olmo_train_runtime_cache/wandb_cache
    export WANDB_CONFIG_DIR=/tmp/olmo_train_runtime_cache/wandb_config
    export OLMO_RUNTIME_CACHE_ROOT=/tmp/olmo_train_runtime_cache
    export OLMO_OUTPUT_ROOT=/tmp/olmo_train_outputs
    export OLMO_LOG_ROOT=/tmp/olmo_train_logs
    export TMPDIR=/tmp
    export TMP=/tmp
    export TEMP=/tmp
    export GIT_LFS_SKIP_SMUDGE=1
    export USE_HUB_KERNELS=NO
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
    export TORCH_DIST_INIT_BARRIER=1
    export TORCH_NCCL_ASYNC_ERROR_HANDLING=1
    export TORCH_NCCL_AVOID_RECORD_STREAMS=1
    export NCCL_DEBUG=WARN
    export NCCL_NVLS_ENABLE=1
    export HTTPX_LOG_LEVEL=WARNING
    export OMP_NUM_THREADS=8
    export HF_XET_HIGH_PERFORMANCE=1
    export CUDNN_PATH=/usr/local/lib/python3.12/site-packages/nvidia/cudnn/include
    export LD_LIBRARY_PATH=/usr/local/cudnn/lib:/usr/local/cuda-13.0/lib64:/usr/local/ucx/lib:/opt/nvidia/nvda_nixl/lib/x86_64-linux-gnu:/opt/nvidia/nvda_nixl/lib64:/usr/lib/x86_64-linux-gnu:/usr/local/nvidia/lib:/usr/local/nvidia/lib64:${LD_LIBRARY_PATH}
    export HF_TOKEN="${HF_TOKEN:-${HUGGING_FACE_HUB_TOKEN:-}}"
    export WANDB_API_KEY="${WANDB_API_KEY:-}"
    export GITHUB_TOKEN="${GITHUB_TOKEN:-${GITHUB_TOKEN_VALUE:-}}"


%post
    mkdir -p /app
    mkdir -p /tmp/olmo_train_runtime_cache/hf /tmp/olmo_train_runtime_cache/xdg /tmp/olmo_train_runtime_cache/torch /tmp/olmo_train_runtime_cache/torchinductor /tmp/olmo_train_runtime_cache/triton /tmp/olmo_train_runtime_cache/vllm
    cd /app
    chmod +x /app/*.sh
    OLMO_CORE_REF="${OLMO_CORE_REF:-main}" \
    OPEN_INSTRUCT_REF="${OPEN_INSTRUCT_REF:-main}" \
    INSTALL_MODAL_SIMP_EXTRAS=1 \
    INSTALL_CONTAINER_BUILD_APT="${INSTALL_CONTAINER_BUILD_APT:-0}" \
    INSTALL_SINGULARITY_CE="${INSTALL_SINGULARITY_CE:-0}" \
    INSTALL_APPTAINER_IN_IMAGE="${INSTALL_APPTAINER_IN_IMAGE:-0}" \
    INSTALL_APEX="${INSTALL_APEX:-1}" \
    INSTALL_MEGATRON_CORE="${INSTALL_MEGATRON_CORE:-1}" \
    /app/install_training_deps.sh

%runscript
    exec python /app/train.py "$@"
