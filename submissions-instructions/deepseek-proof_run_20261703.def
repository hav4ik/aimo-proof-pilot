Bootstrap: docker
From: nvcr.io/nvidia/pytorch:26.03-py3

%files
    ./src/run.py /app/run.py
    ./src/qwen3_6_chat_template.jinja /app/qwen3_6_chat_template.jinja
    ./src/kaggle_evaluation /app/kaggle_evaluation
    ./KAGGLE_PROOF_PILOT.md /app/KAGGLE_PROOF_PILOT.md
    ./src/requirements_run.txt /app/requirements_run.txt

%environment
    HF_HOME=/tmp/hf
    TRANSFORMERS_CACHE=/tmp/hf
    XDG_CACHE_HOME=/tmp/xdg
    HUGGINGFACE_HUB_CACHE=/tmp/hf
    TORCH_HOME=/tmp/torch
    TORCHINDUCTOR_CACHE_DIR=/tmp/torchinductor
    TRITON_CACHE_DIR=/tmp/triton
    VLLM_CACHE_DIR=/tmp/vllm
    PYTHONDONTWRITEBYTECODE=1
    OMP_NUM_THREADS=8


%post
    mkdir -p /app
    mkdir -p /tmp/hf /tmp/xdg /tmp/torch /tmp/torchinductor /tmp/triton /tmp/vllm
    cd /app
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl
    rm -rf /var/lib/apt/lists/*
    python -m pip install --no-cache-dir --root-user-action=ignore --upgrade pip setuptools wheel
    python -m pip install --no-cache-dir --root-user-action=ignore -r /app/requirements_run.txt

%test
    export HOME=/tmp
    test -s /app/qwen3_6_chat_template.jinja
    python -m py_compile /app/run.py
    python /app/run.py --help >/tmp/run_help.txt
    python - <<'PY'
import openai
import pandas
import typer
from importlib.metadata import version
print("vllm", version("vllm"))
print("run imports OK")
PY

%runscript
    exec python /app/run.py "$@"
